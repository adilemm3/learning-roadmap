{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "Bash",
      "Bash(cd ~/Documents/myProjects/learning-roadmap && git *)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/Documents/myProjects/learning-roadmap && git add -A && git diff --cached --quiet || git commit -m \"auto: update $(date +%Y-%m-%d_%H:%M)\""
          }
        ]
      }
    ]
  }
}
